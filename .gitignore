# Python
__pycache__/
*.py[cod]
*.egg-info/

# Editores / IDE
.vscode/
.idea/
*.swp
*.swo

# Sistema
.DS_Store
Thumbs.db

# Logs
*.log
!docs/smoke-tests/*.log

# Secretos / credenciales
.env
.env.*
!.env.example
*.key
*.pem
credentials.json

# Estado per-usuario de Claude Code (allowlist con rutas y PIDs)
.claude/settings.local.json

# Playwright MCP state (snapshots de sesión, no versionados)
.playwright-mcp/

# Lighthouse audit HTMLs (regenerables desde los .json o re-ejecutando
# el runner). Pesan ~1.5 MB cada uno y suman ~36 MB por auditoría
# completa. Los .json son source of truth para análisis programático
# y SÍ se versionan; los .html son revisables visualmente pero no
# necesarios en repo.
docs/audits/*/lighthouse/*.html
