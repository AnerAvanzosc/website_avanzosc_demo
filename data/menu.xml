<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Menu principal ES — Task 1.1 -->
    <!-- 7 items top-level + 4 hijos bajo Soluciones sectoriales = 11 entradas -->
    <!-- Solo ES en esta tarea. EU es scope de Task 2.2. -->

    <!-- 1. Inicio -->
    <record id="menu_inicio" model="website.menu">
        <field name="name">Inicio</field>
        <field name="url">/</field>
        <field name="parent_id" ref="website.main_menu"/>
        <field name="sequence">10</field>
    </record>

    <!-- 2. Soluciones sectoriales — dropdown padre sin URL propia -->
    <record id="menu_soluciones" model="website.menu">
        <field name="name">Soluciones sectoriales</field>
        <field name="url">#</field>
        <field name="parent_id" ref="website.main_menu"/>
        <field name="sequence">20</field>
    </record>

    <!-- 2a. Industrial -->
    <record id="menu_industrial" model="website.menu">
        <field name="name">Industrial</field>
        <field name="url">/industrial</field>
        <field name="parent_id" ref="website_avanzosc_demo.menu_soluciones"/>
        <field name="sequence">10</field>
    </record>

    <!-- 2b. Distribución -->
    <record id="menu_distribucion" model="website.menu">
        <field name="name">Distribución</field>
        <field name="url">/distribucion</field>
        <field name="parent_id" ref="website_avanzosc_demo.menu_soluciones"/>
        <field name="sequence">20</field>
    </record>

    <!-- 2c. Servicios -->
    <record id="menu_servicios" model="website.menu">
        <field name="name">Servicios</field>
        <field name="url">/servicios</field>
        <field name="parent_id" ref="website_avanzosc_demo.menu_soluciones"/>
        <field name="sequence">30</field>
    </record>

    <!-- 2d. Academias -->
    <record id="menu_academias" model="website.menu">
        <field name="name">Academias</field>
        <field name="url">/academias</field>
        <field name="parent_id" ref="website_avanzosc_demo.menu_soluciones"/>
        <field name="sequence">40</field>
    </record>

    <!-- 3. Tienda — apunta a /tienda; redirects 301 a /shop son scope posterior -->
    <record id="menu_tienda" model="website.menu">
        <field name="name">Tienda</field>
        <field name="url">/tienda</field>
        <field name="parent_id" ref="website.main_menu"/>
        <field name="sequence">30</field>
    </record>

    <!-- 4. Formación — apunta a /formacion; redirects 301 a /slides son scope posterior -->
    <record id="menu_formacion" model="website.menu">
        <field name="name">Formación</field>
        <field name="url">/formacion</field>
        <field name="parent_id" ref="website.main_menu"/>
        <field name="sequence">40</field>
    </record>

    <!-- 5. Conócenos -->
    <record id="menu_conocenos" model="website.menu">
        <field name="name">Conócenos</field>
        <field name="url">/conocenos</field>
        <field name="parent_id" ref="website.main_menu"/>
        <field name="sequence">50</field>
    </record>

    <!-- 6. Trabaja con nosotros -->
    <record id="menu_trabaja" model="website.menu">
        <field name="name">Trabaja con nosotros</field>
        <field name="url">/trabaja-con-nosotros</field>
        <field name="parent_id" ref="website.main_menu"/>
        <field name="sequence">60</field>
    </record>

    <!-- 7. Contacto -->
    <record id="menu_contacto" model="website.menu">
        <field name="name">Contacto</field>
        <field name="url">/contacto</field>
        <field name="parent_id" ref="website.main_menu"/>
        <field name="sequence">70</field>
    </record>

</odoo>
