<?xml version="1.0" encoding="utf-8"?>
<!--
    Phase 5 — Página sectorial /distribucion.
    Ref: spec §7, plan Phase 5.

    Archetype destacado: id=5 (Cadena retail multitienda + ecommerce
    con omnicanal) — más visualmente reconocible que el mayorista (id=6)
    para el visitante typical de la sectorial. Decisión sesión 2026-04-29.

    URL EU `/banaketa` (validated D2).
-->
<odoo>
    <!-- Two `<data>` blocks: template (no noupdate, so `-u` updates arch_db
         from disk) + page record (noupdate="1", so admin edits survive
         `-u`). Standard Odoo pattern, ref plan §7.5.2. -->
    <data>

        <template id="page_distribucion" name="Avanzosc · Distribución">
            <t t-call="website.layout">
                <div id="wrap">
                    <div>
                        <t t-call="website_avanzosc_demo.s_avanzosc_hero">
                            <t t-set="hero_claim">Almacén, picking y rutas. Sin Excel intermedios.</t>
                            <t t-set="hero_subtitle">WMS, multi-canal, EDI y marketplaces. Integraciones con balanzas, lectores y SGV. Operativa optimizada en almacenes reales.</t>
                            <t t-set="hero_cta_primary_text">Ver capacidades</t>
                            <t t-set="hero_cta_primary_url">#capabilities</t>
                            <t t-set="hero_cta_secondary_text">Hablar con un técnico</t>
                            <t t-set="hero_cta_secondary_url">/contacto</t>
                        </t>

                        <t t-call="website_avanzosc_demo.s_avanzosc_sector_specifics">
                            <t t-set="sector_key" t-value="'distribucion'"/>
                        </t>

                        <t t-call="website_avanzosc_demo.s_avanzosc_caso_exito">
                            <t t-set="archetype_id" t-value="5"/>
                        </t>

                        <t t-call="website_avanzosc_demo.s_avanzosc_cta_contacto"/>
                    </div>
                </div>
            </t>
        </template>

    </data>

    <data noupdate="1">

        <record id="page_distribucion_record" model="website.page">
            <field name="name">Distribución</field>
            <field name="type">qweb</field>
            <field name="url">/distribucion</field>
            <field name="view_id" ref="page_distribucion"/>
            <field name="is_published" eval="True"/>
            <field name="website_indexed" eval="True"/>
        </record>

    </data>
</odoo>
