<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================
         Task 1.2 — Header desktop layout
         Scope: herencia sobre website.template_header_default para:
           1. Reemplazar botón "Contact Us" por "Acceso clientes".
           2. Eliminar Sign in / User dropdown del navbar_nav.
           3. Activar el selector de idioma (text variant, sin flag).
         Ref: CLAUDE.md §3, §4, §10; spec §8.1; task 1.2.
         ============================================================ -->

    <!-- 1. Botón «Acceso clientes» — override de oe_structure_header_default_1.
         Hereda website.template_header_default_oe_structure_header_default_1,
         que es el template que rellena la zona oe_structure con el botón
         "Contact Us" estándar de Odoo. Lo reemplazamos con nuestro botón.
         La clase s_avanzosc_acceso_clientes sirve de hook CSS en _header.scss.
         href provisional: /web/login — URL final del portal pendiente [?] #2 spec.
         Ref: CLAUDE.md §4 (IDs prefijados), task 1.2 punto 2. -->
    <template id="header_acceso_clientes"
              name="Header: Acceso clientes button"
              inherit_id="website.template_header_default_oe_structure_header_default_1">
        <!-- Reemplazamos el anchor «Contact Us» por «Acceso clientes».
             Se mantiene la estructura oe_structure/section/container para no
             romper el padding y la grilla del header por defecto.
             Asume website usa template_header_default. Variantes
             (_align_center, _align_right, _hamburger) no se contemplan en v1
             per CLAUDE.md §10 (sin Website Builder). Si se cambia a otra
             variante, este xpath no matchea y el botón desaparece sin error. -->
        <xpath expr="//a[@href='/contactus']" position="replace">
            <!-- href provisional /web/login — bloqueo blando [?] #2 spec (URL portal). -->
            <a href="/web/login"
               class="btn btn-primary ml-4 s_avanzosc_acceso_clientes">
                Acceso clientes
            </a>
        </xpath>
    </template>

    <!-- 2. Eliminar Sign in y User dropdown del navbar_nav.
         Hereda website.template_header_default (que pone esas dos llamadas
         dentro del bloque <t t-call="website.navbar_nav">).
         Con «Acceso clientes» ya en la zona oe_structure_header_default_1
         como botón destacado, no queremos duplicar el acceso al portal dentro
         del nav. Se eliminan ambas llamadas.
         Ref: CLAUDE.md §10 (no duplicar accesos), task 1.2 punto 3. -->
    <template id="header_remove_portal_nav_items"
              name="Header: remove Sign in and User dropdown from nav"
              inherit_id="website.template_header_default">
        <!-- Eliminar placeholder Sign in del navbar. portal.placeholder_user_sign_in
             muestra el enlace «Sign in» solo cuando el visitante no está
             autenticado; con el botón «Acceso clientes» cubrimos ese caso. -->
        <xpath expr="//t[@t-call='portal.placeholder_user_sign_in']"
               position="replace"/>
        <!-- Eliminar portal.user_dropdown del navbar: el dropdown de usuario
             autenticado. Los usuarios con portal tienen acceso desde el menú
             de My Account vía /web/login o /my/home. -->
        <xpath expr="//t[@t-call='portal.user_dropdown']"
               position="replace"/>
    </template>

    <!-- 3a. Activar header_language_selector (dropdown text variant).
          El template website.header_language_selector hereda de
          website.placeholder_header_language_selector y, cuando active=True,
          inyecta el widget dropdown de idiomas en el header.
          Estaba active=False en la instalación base. Lo activamos aquí.
          Ref: CLAUDE.md §4 (record con xml_id externo), task 1.2 punto 4. -->
    <record id="website.header_language_selector" model="ir.ui.view">
        <!-- Activar el selector de idioma (dropdown text) en el header. -->
        <field name="active" eval="True"/>
    </record>

    <!-- 3b. Desactivar header_language_selector_flag.
          Este template hijo añade banderas al selector. Con active=False
          el selector mostrará solo texto (ES / Euskara) sin iconos de bandera.
          Ref: task 1.2 punto 4 (text variant, sin flag). -->
    <record id="website.header_language_selector_flag" model="ir.ui.view">
        <!-- Desactivar variante de bandera: queremos texto limpio, no flags. -->
        <!-- noupdate omitido: si se ejecuta `-u website` sin nuestro módulo
             cargado simultáneamente, el flag puede revertir a True. Asumimos
             que el módulo `website_avanzosc_demo` se mantiene cargado en
             producción y se actualiza junto con `website` cuando aplique. -->
        <field name="active" eval="False"/>
    </record>

    <!-- ============================================================
         Task 1.3 — Sticky header con estado «scrolled»
         ============================================================ -->

    <!-- Desactivar la opción de Odoo «Header Visibility Standard».
         Por qué: el template añade la clase `o_header_standard` al header,
         lo que dispara el widget `publicWidget.registry.StandardAffixedHeader`
         (addons/website/static/src/js/content/menu.js:238) que aplica un
         comportamiento incompatible con el spec de Task 1.3 — desliza el
         header off-screen con `transform: translate(0, -100%)` cuando el
         scroll supera la altura del header, y lo hace re-aparecer al pasar
         `scrolledPoint` (300px por defecto). Spec §8.1 + briefing 1.3 piden
         lo opuesto: el header se mantiene SIEMPRE visible (sticky) y solo
         compacta padding + añade sombra al pasar ~100px.
         Sin la clase, ningún widget de header animado matchea el selector,
         y nuestro position:sticky CSS más el handler de scroll de main.js
         operan limpiamente sin pelear con el framework.

         Trade-off menor: perdemos `o_top_fixed_element` toggle (lo añade el
         widget desactivado, lo consume el snippet `s_table_of_content` para
         compensar el offset al hacer scroll a anchors). En v1 no hay TOC, no
         impacta. Si en futuras tareas se necesita TOC, replicar la clase
         desde nuestra propia lógica.

         noupdate omitido por las mismas razones documentadas en
         header_language_selector_flag (active=False persiste mientras nuestro
         módulo se mantenga cargado y se actualice junto con `website`). -->
    <record id="website.header_visibility_standard" model="ir.ui.view">
        <field name="active" eval="False"/>
    </record>

    <!-- ============================================================
         Task 1.4 — Footer Avanzosc (4 columnas + bottom strip)
         Spec §8.2, CLAUDE.md §3.
         ============================================================ -->

    <!-- Desactivar el footer default «footer_custom» (3-col Useful Links /
         About us / Connect with us). Sustituimos por nuestro propio template
         `footer_avanzosc` que hereda directamente de `website.layout`, igual
         patrón que las otras 8 variantes core (template_footer_descriptive,
         _centered, _links, etc.). Mutuamente excluyente — solo un template
         de la familia footer puede estar activo a la vez. -->
    <record id="website.footer_custom" model="ir.ui.view">
        <field name="active" eval="False"/>
    </record>

    <!-- Desactivar la variante con bandera del switcher de idiomas en footer.
         Mismo patrón que `header_language_selector_flag` (Task 1.2):
         queremos texto-only en footer también, coherente con el header.
         `portal.footer_language_selector` se mantiene activo (es el wrapper
         canónico que inyecta el selector tras `o_footer_copyright_name`). -->
    <record id="website.footer_language_selector_flag" model="ir.ui.view">
        <field name="active" eval="False"/>
    </record>

    <!-- Footer principal — 4 columnas: Avanzosc / Soluciones / Empresa / Legal.
         Hereda website.layout (no footer_custom) y reemplaza el contenido
         del placeholder #footer.

         Strings en castellano (idioma fuente per spec D1 ES + EU). Las
         traducciones EU viven en `i18n/eu.po` y se aplican automáticamente
         cuando el idioma activo del request es `eu_ES`. NO usamos t-if/else
         manual por idioma — usamos el sistema canónico de traducciones de
         Odoo (extracción automática de QWeb, .po files, ir.translation).

         Páginas legales (/aviso-legal, /politica-privacidad,
         /politica-cookies): los enlaces apuntan a URLs que aún NO existen
         como `website.page` — devolverán 404 hasta su tarea posterior.
         Esperado, no es bug. -->
    <template id="footer_avanzosc"
              name="Footer Avanzosc"
              inherit_id="website.layout">
        <xpath expr="//div[@id='footer']" position="replace">
            <div id="footer" class="oe_structure oe_structure_solo s_avanzosc_footer" t-ignore="true" t-if="not no_footer">
                <section class="s_avanzosc_footer_main">
                    <div class="container">
                        <div class="row">
                            <!-- Columna 1: Avanzosc — logo + claim. -->
                            <div class="col-lg-3 col-md-6 mb-4 s_avanzosc_footer_brand">
                                <a href="/" class="d-block mb-3">
                                    <span t-field="res_company.logo"
                                          t-options="{'widget': 'image', 'class': 'img-fluid s_avanzosc_footer_logo', 'alt-field': 'name'}"/>
                                </a>
                                <p class="s_avanzosc_footer_claim">Odoo industrial de verdad, desde 2008.</p>
                            </div>
                            <!-- Columna 2: Soluciones (4 sectoriales).
                                 URLs idénticas a las del dropdown del header
                                 (data/menu.xml + post_init_hook). -->
                            <div class="col-lg-3 col-md-6 mb-4">
                                <h5 class="s_avanzosc_footer_heading">Soluciones</h5>
                                <ul class="list-unstyled">
                                    <li><a href="/industrial">Industrial</a></li>
                                    <li><a href="/distribucion">Distribución</a></li>
                                    <li><a href="/servicios">Servicios</a></li>
                                    <li><a href="/academias">Academias</a></li>
                                </ul>
                            </div>
                            <!-- Columna 3: Empresa. URLs idénticas a los
                                 menus top-level correspondientes. -->
                            <div class="col-lg-3 col-md-6 mb-4">
                                <h5 class="s_avanzosc_footer_heading">Empresa</h5>
                                <ul class="list-unstyled">
                                    <li><a href="/conocenos">Conócenos</a></li>
                                    <li><a href="/trabaja-con-nosotros">Empleo</a></li>
                                    <li><a href="/contacto">Contacto</a></li>
                                </ul>
                            </div>
                            <!-- Columna 4: Legal. Las 3 páginas son
                                 placeholder (404 hasta tarea posterior). -->
                            <div class="col-lg-3 col-md-6 mb-4">
                                <h5 class="s_avanzosc_footer_heading">Legal</h5>
                                <ul class="list-unstyled">
                                    <li><a href="/aviso-legal">Aviso Legal</a></li>
                                    <li><a href="/politica-privacidad">Política de Privacidad</a></li>
                                    <li><a href="/politica-cookies">Política de Cookies</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </xpath>
    </template>

    <!-- Copyright text — sustituye el span hardcoded de `website.layout`
         (línea 178-179: «Copyright © Company name») por el identificador
         legal real de Avanzosc S.L. (CIF + razón social). Per spec §13.

         Por qué replace y no edit: `website.layout` ya hace `position="replace"`
         del span original de `web.layout`. Encadenamos otro replace para
         tener el último valor. El selector `//footer//span[hasclass(...)]`
         es idéntico al que usa `website.layout` — match seguro.

         portal.footer_language_selector inserta el switcher mediante
         `position="after"` sobre el mismo selector — se ejecuta después de
         nuestro replace y opera sobre nuestro span (mismo class), sin
         conflicto. Cadena de orden: web.layout (define) → website.layout
         (replace 1) → website_avanzosc_demo (replace 2) → portal (after).

         Texto NO se traduce (CIF e identificador legal idéntico ES/EU). -->
    <template id="footer_copyright_avanzosc"
              name="Footer Copyright Avanzosc"
              inherit_id="website.layout">
        <xpath expr="//footer//span[hasclass('o_footer_copyright_name')]" position="replace">
            <span class="o_footer_copyright_name mr-2">© 2026 Avanzosc S.L. — CIF B20875340</span>
        </xpath>
    </template>
</odoo>
