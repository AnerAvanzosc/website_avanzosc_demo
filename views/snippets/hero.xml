<?xml version="1.0" encoding="utf-8"?>
<!--
    Task 3.10 — s_avanzosc_hero snippet.
    Ref: spec §6.1 §9.2, plan §3.10, CLAUDE.md §11 D2 «Claim de la home»
    (validado, NO TRANSLATION DRAFT) + decisiones B-G sesión 2026-04-28.

    Primera sección de la home (sección 1 funnel). Captura atención + claim
    diferenciador + 2 CTAs hacia el funnel.

    Decisiones aplicadas (CLAUDE.md §11 hero deferred B-G):
      A — claim ES/EU validados D2 (idénticos al footer brand col).
      B — subtítulo: «Migración OpenUpgrade, módulos OCA y localización
          fiscal española. Para industria, distribución, servicios y
          academias.»
      C — 2 CTAs: «Ver soluciones» → #sectores, «Hablar con nosotros»
          → /contacto.
      D — Background blanco neutral-0, headline neutral-900 (CLAUDE.md
          §9.8 jerarquía por tamaño antes que por color).
      E — SIN imagen en v1. Comentario TODO #spec-q8 marca el punto donde
          insertar foto/illustration cuando se cierre la sesión fotográfica.
      F — min-height: 600px desktop, 480px mobile (en _hero.scss).
      G — animación completa: Splitting.js letter-split + GSAP timeline.

    NO en builder (D4).
-->
<odoo>
    <template id="s_avanzosc_hero" name="Avanzosc · Hero">
        <!--
            Parametrización (Phase 5): cada llamador puede sobrescribir
            los 6 fragmentos de copy via `<t t-call>` body con `<t t-set>`.
            Forma t-set body (no t-value) preserva el contenido como
            QWeb-rendered text, lo que mantiene la traducibilidad
            automática en eu.po (extracción del extractor de Odoo
            recoge el texto del body como msgid).

            Defaults aquí = los valores de la home Phase 4. Cualquier
            llamador sin body usa los defaults. Sectoriales (Phase 5)
            sobrescriben con copy específico por sector.
        -->
        <t t-if="not hero_claim">
            <t t-set="hero_claim">Odoo industrial de verdad, desde 2008.</t>
        </t>
        <t t-if="not hero_subtitle">
            <t t-set="hero_subtitle">Migración OpenUpgrade, módulos OCA y localización fiscal española. Para industria, distribución, servicios y academias.</t>
        </t>
        <t t-if="not hero_cta_primary_text">
            <t t-set="hero_cta_primary_text">Ver soluciones</t>
        </t>
        <t t-if="not hero_cta_primary_url">
            <t t-set="hero_cta_primary_url">#sectores</t>
        </t>
        <t t-if="not hero_cta_secondary_text">
            <t t-set="hero_cta_secondary_text">Hablar con nosotros</t>
        </t>
        <t t-if="not hero_cta_secondary_url">
            <t t-set="hero_cta_secondary_url">/contacto</t>
        </t>

        <section class="s_avanzosc_hero" data-name="Avanzosc Hero">
            <!-- Pieza A — Hero decoration (technical blueprint, sutil).
                 2 layers absolutamente posicionados detrás del contenido,
                 pointer-events:none + aria-hidden=true para que no
                 interfieran con interaction ni screen readers. El claim
                 sigue siendo el LCP element semántico.
                 Layer 1 (atrás): grid de puntos vía CSS radial-gradient
                 + mask que desvanece el centro.
                 Layer 2 (delante): SVG inline con 3 trazos asimétricos
                 que enmarcan el texto sin cruzarlo.
                 Parallax + entrance fade gestionados desde hero.js. -->
            <div class="s_avanzosc_hero_grid" aria-hidden="true"></div>
            <svg class="s_avanzosc_hero_lines"
                 viewBox="0 0 100 100"
                 preserveAspectRatio="none"
                 aria-hidden="true"
                 focusable="false">
                <!-- Main: long curve bottom, passing under text area. -->
                <path class="s_avanzosc_hero_lines_main"
                      d="M -2 78 Q 50 90 102 72"
                      fill="none" stroke="currentColor" stroke-width="1"
                      vector-effect="non-scaling-stroke"/>
                <!-- Secondary 1: short diagonal top-right. -->
                <path class="s_avanzosc_hero_lines_secondary"
                      d="M 95 8 L 70 28"
                      fill="none" stroke="currentColor" stroke-width="1"
                      vector-effect="non-scaling-stroke"/>
                <!-- Secondary 2: short diagonal top-left (hidden mobile). -->
                <path class="s_avanzosc_hero_lines_secondary s_avanzosc_hero_lines_secondary_topleft"
                      d="M -2 25 L 18 18"
                      fill="none" stroke="currentColor" stroke-width="1"
                      vector-effect="non-scaling-stroke"/>
            </svg>
            <div class="container">
                <div class="s_avanzosc_hero_inner">
                    <h1 class="s_avanzosc_hero_claim"><t t-esc="hero_claim"/></h1>
                    <p class="s_avanzosc_hero_subtitle"><t t-esc="hero_subtitle"/></p>
                    <div class="s_avanzosc_hero_actions">
                        <a t-att-href="hero_cta_primary_url" class="btn btn-primary btn-lg s_avanzosc_hero_cta_primary"><t t-esc="hero_cta_primary_text"/></a>
                        <a t-att-href="hero_cta_secondary_url" class="s_avanzosc_hero_cta_secondary"><t t-esc="hero_cta_secondary_text"/></a>
                    </div>
                    <!-- TODO #spec-q8: evaluar foto/illustration aquí cuando se
                         cierre sesión fotográfica del equipo Avanzosc. v1 va
                         sin imagen per CLAUDE.md §9.6 (NO stock photos) y
                         decisión E sesión 2026-04-28. Punto de inserción
                         estable: dentro de .s_avanzosc_hero_inner, debajo de
                         .s_avanzosc_hero_actions o en col paralela. -->
                </div>
            </div>
        </section>
    </template>
</odoo>
