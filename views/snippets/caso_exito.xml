<?xml version="1.0" encoding="utf-8"?>
<!--
    Task 3.6 — s_avanzosc_caso_exito snippet.
    Ref: spec §6.6 §10, plan §3.6, CLAUDE.md §11 D3 «Caso de éxito en home
    selección configurable» + Q2 cerrada (anonymous-first hardcoded en QWeb).

    ARCHETYPE DICT: estructura espejo del futuro modelo
    `website.avanzosc.archetype` (v2). Migrable sin tocar markup — basta con
    sustituir el `t-set` literal por una query al modelo.
    Campos: {id, title, sector, subsector, capability_summary,
             capability_details: [str, ...]}.

    8 archetypes anónimos per CLAUDE.md §11 («Casos de éxito destacados»):
      1-4: Industrial (mecanizado / química / alimentaria / textil)
      5-6: Distribución (retail / mayorista)
      7  : Servicios
      8  : Academias

    Selección en home: vía `ir.config_parameter`
    `website_avanzosc_demo.featured_archetype_id` (default '1'). Cambio en
    Settings → Technical → Parameters (o vía shell) sin redeploy. El record
    del param vive en `data/config_parameters.xml` con `noupdate="1"` para
    que el valor admin-editado persista a través de `-u`.

    Override de archetype_id por `t-call`: si `archetype_id` se pasa via
    `t-call` (e.g. en una página sectorial Phase 5), se usa ese ID
    directamente, ignorando el config_parameter. Permite reutilizar el
    snippet en sectoriales filtrando por archetype específico.

    Anonymous-first: SIN nombre de cliente real, SIN logo, SIN métricas
    inventadas (CLAUDE.md §11 prohíbe métricas falsas). Visual placeholder:
    SVG dashboard inline 600×400 wireframe-style.

    Reveal: simple fade-in via widget genérico AvanzoscReveal
    (`data-avanzosc-reveal`). Sin parallax (decisión sesión 2026-04-28
    simplificación del plan §3.6 que mencionaba parallax sutil).

    EU NO en v1 — diferido a tarea posterior cuando se elija el archetype
    activo definitivo y se traduzca solo ese. Documentado en commit body.

    NO en builder (D4).
-->
<odoo>
    <template id="s_avanzosc_caso_exito" name="Avanzosc · Caso de éxito">
        <section class="s_avanzosc_caso_exito" data-name="Avanzosc Caso de éxito" data-avanzosc-reveal="">
            <div class="container">
                <!-- ARCHETYPE DICT inline. Estructura espejo del futuro modelo
                     website.avanzosc.archetype (v2). Migrable sin tocar markup. -->
                <t t-set="archetypes" t-value="{
                    1: {
                        'title': 'Fabricante metal-mecánico (50-200 empleados)',
                        'sector': 'Industrial',
                        'subsector': 'Mecanizado / metalúrgico exportador',
                        'capability_summary': 'Migración completa Excel → Odoo MRP con trazabilidad y multidivisa.',
                        'capability_details': [
                            'MRP por capacidad finita y planificación por taller.',
                            'Configurador multivariante para exportación.',
                            'Integración con PLCs vía OCA/connector_mes.',
                            'Trazabilidad por lote/serie + EDI con clientes.',
                            'Multidivisa con tipo de cambio diario automático.',
                        ],
                    },
                    2: {
                        'title': 'Industria química media (~150 empleados)',
                        'sector': 'Industrial',
                        'subsector': 'Química con producción por batch + ADR',
                        'capability_summary': 'Trazabilidad batch + cumplimiento ADR + presentación SILICIE automatizada.',
                        'capability_details': [
                            'Vencimientos automáticos por lote y producto.',
                            'Fichas de seguridad versionadas y publicación web.',
                            'Etiquetado ADR con códigos UN y cantidades.',
                            'Presentación SILICIE mensual sin intervención manual.',
                            'Calidad: ensayos por batch con criterios pasa/no-pasa.',
                        ],
                    },
                    3: {
                        'title': 'Productor alimentario (4 plantas)',
                        'sector': 'Industrial',
                        'subsector': 'Alimentaria con AECOC + balanzas',
                        'capability_summary': 'Trazabilidad lote y alérgenos en milisegundos. Integración nativa con balanzas de envasado.',
                        'capability_details': [
                            'Etiquetado AECOC con compliance retail.',
                            'Trazabilidad lote consultable de cliente final → materia prima.',
                            'Alérgenos validados por receta y allergen-cross con BOM.',
                            'Conexión TCP/IP con balanzas de envasado.',
                            'Lectura/grabación de pesos automática a OF.',
                        ],
                    },
                    4: {
                        'title': 'Marca textil con producción para terceros',
                        'sector': 'Industrial',
                        'subsector': 'Textil con temporadas y OEMs',
                        'capability_summary': 'Variantes talla-color con grid editable + planificación PV/OI + producción para terceros.',
                        'capability_details': [
                            'Grid talla-color editable como matriz Excel.',
                            'Planificación por temporada (Primavera-Verano / Otoño-Invierno).',
                            'Producción para OEMs con escandallos diferenciados.',
                            'Integraciones con tiendas online del cliente.',
                            'Reportería por colección con margen unitario.',
                        ],
                    },
                    5: {
                        'title': 'Cadena retail multitienda + ecommerce (8 puntos físicos)',
                        'sector': 'Distribución',
                        'subsector': 'Retail con omnicanal',
                        'capability_summary': 'POS multitienda + sync ecommerce + multialmacén con devoluciones omnicanal.',
                        'capability_details': [
                            'POS Odoo en cada tienda + central de compras.',
                            'Sync con ecommerce externo vía webhooks.',
                            'Multialmacén con stock real consolidado.',
                            'Devolución cross-tienda y vía web.',
                            'Cierre de caja diario con conciliación bancaria.',
                        ],
                    },
                    6: {
                        'title': 'Distribuidor mayorista (catálogo +50.000 referencias)',
                        'sector': 'Distribución',
                        'subsector': 'B2B mayorista con configurador',
                        'capability_summary': 'Configurador masivo + listas de precios por cliente + EDI + packs.',
                        'capability_details': [
                            'Configurador para producto con variantes y compatibilidad.',
                            'Listas de precios por cliente y por volumen.',
                            'EDI con clientes-cadena (formato EDIFACT).',
                            'Packs y kits con cálculo automático de coste.',
                            'Catálogo importable desde excel del proveedor.',
                        ],
                    },
                    7: {
                        'title': 'Servicio IT/SAT con técnicos en ruta',
                        'sector': 'Servicios',
                        'subsector': 'Soporte técnico con SLA',
                        'capability_summary': 'Helpdesk + planning geolocalizado + facturación recurrente con SLA por contrato.',
                        'capability_details': [
                            'Tickets con SLA por cliente y prioridad.',
                            'Planning de técnicos con vista calendario y geo.',
                            'Partes de horas firmados desde móvil.',
                            'Facturación recurrente por contrato + horas extra.',
                            'Reportes de cumplimiento de SLA mensuales.',
                        ],
                    },
                    8: {
                        'title': 'Grupo educativo multicentro (4 colegios)',
                        'sector': 'Academias',
                        'subsector': 'Educación con comunicación familias',
                        'capability_summary': 'Matriculación online + gestión académica multicentro + comunicación con familias.',
                        'capability_details': [
                            'Matriculación online con generación automática de docs.',
                            'Calendarios y horarios por curso/centro.',
                            'Evaluaciones con reportes a familias.',
                            'Comunicación bidireccional vía portal familias.',
                            'Pagos recurrentes (mensualidad, comedor, extraescolares).',
                        ],
                    },
                }"/>

                <!-- Resolver archetype activo. archetype_id puede venir via t-call;
                     si no, leemos el config_parameter (default '1'). -->
                <t t-if="not archetype_id"
                   t-set="archetype_id"
                   t-value="int(request.env['ir.config_parameter'].sudo().get_param('website_avanzosc_demo.featured_archetype_id', '1'))"/>
                <t t-set="archetype" t-value="archetypes.get(archetype_id, archetypes.get(1))"/>

                <!-- Header sección -->
                <div class="row mb-4">
                    <div class="col-12 text-center">
                        <h2 class="s_avanzosc_caso_exito_eyebrow">Caso de éxito</h2>
                    </div>
                </div>

                <!-- Card principal -->
                <div class="row">
                    <div class="col-12 col-lg-7 s_avanzosc_caso_exito_text">
                        <p class="s_avanzosc_caso_exito_meta">
                            <span t-esc="archetype.get('sector')"/>
                            ·
                            <span t-esc="archetype.get('subsector')"/>
                        </p>
                        <h3 class="s_avanzosc_caso_exito_title" t-esc="archetype.get('title')"/>
                        <p class="s_avanzosc_caso_exito_summary" t-esc="archetype.get('capability_summary')"/>
                        <ul class="s_avanzosc_caso_exito_details">
                            <t t-foreach="archetype.get('capability_details', [])" t-as="detail">
                                <li t-esc="detail"/>
                            </t>
                        </ul>
                    </div>
                    <div class="col-12 col-lg-5 s_avanzosc_caso_exito_visual">
