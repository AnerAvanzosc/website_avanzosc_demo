                            <rect x="220" y="270" width="40" height="100" rx="2" fill="#E85D2F"/>
                            <rect x="280" y="220" width="40" height="150" rx="2" fill="#E85D2F"/>
                            <rect x="340" y="200" width="40" height="170" rx="2" fill="#E85D2F"/>

                            <!-- Donut placeholder (simplificado) -->
