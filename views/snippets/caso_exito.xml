                            <!-- KPI cards row -->
                            <rect x="20" y="80" width="180" height="80" rx="6" fill="#F4F5F7"/>
                            <rect x="35" y="95" width="60" height="8" rx="2" fill="#D3D7DC"/>
                            <rect x="35" y="115" width="100" height="20" rx="3" fill="#0F1419"/>
