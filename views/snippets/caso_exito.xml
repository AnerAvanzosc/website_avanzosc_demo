                            <rect x="225" y="115" width="100" height="20" rx="3" fill="#0F1419"/>
                            <rect x="225" y="145" width="80" height="6" rx="2" fill="#D3D7DC"/>

                            <rect x="400" y="80" width="180" height="80" rx="6" fill="#F4F5F7"/>
                            <rect x="415" y="95" width="60" height="8" rx="2" fill="#D3D7DC"/>
                            <rect x="415" y="115" width="100" height="20" rx="3" fill="#0F1419"/>
                            <rect x="415" y="145" width="80" height="6" rx="2" fill="#D3D7DC"/>

                            <!-- Bar chart silhouette -->
                            <rect x="20" y="180" width="370" height="200" rx="6" fill="#F4F5F7"/>
                            <rect x="40" y="320" width="40" height="50" rx="2" fill="#E85D2F"/>
                            <rect x="100" y="290" width="40" height="80" rx="2" fill="#E85D2F"/>
