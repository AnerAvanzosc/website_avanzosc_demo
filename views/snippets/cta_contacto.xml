<?xml version="1.0" encoding="utf-8"?>
<!--
    Task 3.4 — s_avanzosc_cta_contacto snippet.
    Ref: spec §6.5 / §6.9, plan §3.4 (adaptado per briefing sesión
    2026-04-28: 2 CTAs en lugar del form HTML5 del plan original; el
    form vive en /contacto que es la landing de Phase 6).

    CTA final de la home, antes del footer. Empuja al funnel «habla con
    nosotros». Background neutral-900 oscuro — contraste con secciones
    blancas previas y mismo tono que el footer, preparando el cierre
    visual de la home.

    2 CTAs:
      - Primary: «Contactar» linkeando a /contacto (la landing form
        Phase 6 cubre el form HTML5 del plan original).
      - Secondary: «Ver casos de éxito» linkeando a #timeline. El
        snippet s_avanzosc_timeline solo vive en home; el snippet
        cta_contacto se incluye en home + 4 sectoriales + /contacto.
        Detección dinámica: si el path actual es la home (ES `/` o
        EU `/eu_ES/` resuelto vía url_for('/')) usamos same-page
        anchor `#timeline` y el smooth scroll del Commit 1 sub-bloque
        A lo lleva ahí. En cualquier otro path usamos cross-page
        anchor `<home>#timeline` (con prefijo de lang preservado por
        url_for) — el bootstrap del Commit 1 hace el scroll suave al
        cargar la home destino. Decisión post-v1 sub-bloque A bonus.

    Heading y subtítulo SÍ se traducen — DRAFT EU en eu.po per Q1.

    Reveal: simple fade+translateY igual que pilares (decisión sesión
    2026-04-28: Splitting.js letter stagger reservado para 3.10 hero,
    donde es la animación estrella). Stagger entre heading / subtítulo
    / actions: 0/200/400ms via :nth-child + transition-delay en SCSS.

    NO en builder (D4).
-->
<odoo>
    <template id="s_avanzosc_cta_contacto" name="Avanzosc · CTA Contacto">
        <!-- Detección de home robusta entre ES y EU. En Odoo 14 con lang
             routing, request.httprequest.path puede ser '/' (Odoo strippea
             el prefijo lang antes de routear) o '/eu_ES/' (con prefijo
             literal). url_for('/') siempre devuelve la home con prefijo
             aplicado: '/' en ES, '/eu_ES/' en EU. is_home cubre ambos
             casos: path raw '/' o path coincidente con url_for. Same-page
             usa '#timeline'; cross-page prepende url_for('/') para
             preservar el idioma al navegar a la home. -->
        <t t-set="path" t-value="request.httprequest.path"/>
        <t t-set="home_url" t-value="url_for('/')"/>
        <t t-set="is_home" t-value="path == '/' or path == home_url"/>
        <t t-set="timeline_href" t-value="'#timeline' if is_home else home_url + '#timeline'"/>
        <section class="s_avanzosc_cta_contacto" data-name="Avanzosc CTA Contacto" data-avanzosc-reveal="">
            <div class="container">
                <div class="s_avanzosc_cta_contacto_inner">
                    <h2 class="s_avanzosc_cta_contacto_heading">¿Hablamos?</h2>
                    <p class="s_avanzosc_cta_contacto_text">Cuéntanos tu caso. Respondemos en 24h laborables.</p>
                    <div class="s_avanzosc_cta_contacto_actions">
                        <a href="/contacto" class="btn btn-primary btn-lg s_avanzosc_cta_contacto_primary">Contactar</a>
                        <a t-att-href="timeline_href" class="s_avanzosc_cta_contacto_secondary">Ver casos de éxito</a>
                    </div>
                </div>
            </div>
        </section>
    </template>
</odoo>
