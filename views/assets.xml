<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Registro de assets del frontend vía herencia XML de web.assets_frontend.
         En Odoo 14 NO se usa la clave 'assets' del manifest (eso es v15+). -->
    <template id="assets_frontend"
              name="website_avanzosc_demo assets frontend"
              inherit_id="web.assets_frontend">
        <xpath expr="." position="inside">
            <!-- Variables primero: el bundle concatena en orden, así que el
                 SCSS posterior puede usar las variables definidas aquí. -->
            <link rel="stylesheet"
                  type="text/scss"
                  href="/website_avanzosc_demo/static/src/scss/_variables.scss"/>
            <link rel="stylesheet"
                  type="text/scss"
                  href="/website_avanzosc_demo/static/src/scss/main.scss"/>
            <script type="text/javascript"
                    src="/website_avanzosc_demo/static/src/js/main.js"/>
        </xpath>
    </template>

    <!-- Inyección de fuentes externas y Lucide CDN en <head>.
         Se hereda web.layout (raíz de toda la jerarquía de layouts de Odoo)
         para que las etiquetas aparezcan en <head> en todas las páginas del
         sitio web. Los <link rel="preconnect"> y el <script> de Lucide deben
         estar en <head> — no en el bundle web.assets_frontend — ya que el
         bundler concatena recursos locales y pasaría las URLs externas como
         CSS @import, perdiendo las directivas preconnect y el scope global de
         la variable `lucide`.
         Ref: spec §3.3 (pipeline de assets, punto 1-2), CLAUDE.md §9.4, §9.7. -->
    <template id="head_external_assets"
              name="website_avanzosc_demo head: Google Fonts + Lucide + GSAP + Splitting + Lenis"
              inherit_id="web.layout">
        <!-- Ancla: después del último elemento de <head> (position inside
             añade al final del contenedor, antes del cierre </head>).
             Esto garantiza que nuestros recursos externos se cargan en <head>
             independientemente del orden en que otras herencias modifiquen
             la sección head. -->
        <xpath expr="//head" position="inside">
            <!-- 1. Google Fonts — preconnect (mejora TTFB de las fuentes) -->
            <link rel="preconnect" href="https://fonts.googleapis.com"/>
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin=""/>

            <!-- 2. Google Fonts — stylesheet:
                 - Space Grotesk 500, 600 (headings H1-H3, CLAUDE.md §9.4)
                 - Inter 400, 500, 600 (body copy, CLAUDE.md §9.4)
                 - JetBrains Mono 400 (código/datos técnicos, CLAUDE.md §9.4) -->
            <link rel="stylesheet"
                  href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600&amp;family=Inter:wght@400;500;600&amp;family=JetBrains+Mono:wght@400&amp;display=swap"/>

            <!-- 3. Splitting.js 1.0.6 CSS — base styles for split word/char nodes.
                 Debe ir en <head> con las demás hojas de estilo para que los
                 estilos estén disponibles antes del primer paint.
                 Ref: spec §9.1 tabla de versiones. -->
            <link rel="stylesheet"
                  href="https://cdn.jsdelivr.net/npm/splitting@1.0.6/dist/splitting.css"/>

            <!-- 4. Lucide Icons 0.453.0 UMD build — expone el global `lucide`.
                 Sin atributo defer: ejecuta síncronamente durante el parse,
                 antes de que los bundles defer de Odoo arranquen los widgets.
                 La llamada lucide.createIcons() vive en main.js dentro de
                 publicWidget.AvanzoscRoot.start(), que dispara después de
                 que el módulo Odoo esté cargado.
                 Ref: CLAUDE.md §9.7, spec §9 tabla de versiones. -->
            <script type="text/javascript"
                    src="https://cdn.jsdelivr.net/npm/lucide@0.453.0/dist/umd/lucide.min.js"/>

            <!-- 5. GSAP 3.12.5 — core. Debe cargar antes de cualquier plugin.
                 Sin defer: expone el global `gsap` síncronamente.
                 Ref: spec §9.1 tabla de versiones. -->
            <script type="text/javascript"
                    src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"/>

            <!-- 6. GSAP ScrollTrigger 3.12.5 — plugin. Requiere core GSAP cargado
                 previamente (orden garantizado por posición en este bloque).
                 Ref: spec §9.1 tabla de versiones. -->
            <script type="text/javascript"
                    src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"/>

            <!-- 7. Splitting.js 1.0.6 JS — reemplazo MIT de GSAP SplitText.
                 Expone el global `Splitting`. Usado en hero para split por letra.
                 Ref: spec §9.1 (nota: descarte de SplitText en favor de Splitting.js MIT). -->
            <script type="text/javascript"
                    src="https://cdn.jsdelivr.net/npm/splitting@1.0.6/dist/splitting.min.js"/>

            <!-- 8. Lenis 1.0.42 — smooth scroll global. Expone el global `Lenis`.
                 La instancia se crea en Task 0.6; aquí solo se registra la librería.
                 Ref: spec §9.1 tabla de versiones, CLAUDE.md §5 (smooth scroll con Lenis). -->
            <script type="text/javascript"
                    src="https://cdn.jsdelivr.net/npm/@studio-freight/lenis@1.0.42/dist/lenis.min.js"/>
        </xpath>
    </template>
</odoo>
